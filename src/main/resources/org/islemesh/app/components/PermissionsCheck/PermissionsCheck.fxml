<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="14"
      styleClass="permissions-check"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.islemesh.app.components.PermissionsCheck.PermissionsCheckController">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <Label text="Isle Mesh" styleClass="title"/>

    <Label fx:id="roleLabel"
           text="Role: ..."
           styleClass="role-badge"/>

    <Label text="Required Permissions"
           styleClass="subtitle"/>

    <VBox fx:id="permissionsList"
          spacing="8"
          styleClass="permissions-list">
        <padding>
            <Insets top="4" right="0" bottom="4" left="0"/>
        </padding>
    </VBox>

    <Label fx:id="statusLabel"
           text=""
           styleClass="status-text"
           wrapText="true"
           textAlignment="CENTER"
           visible="false"
           managed="false"/>

    <Button fx:id="grantButton"
            text="Grant Permissions"
            styleClass="btn, btn-primary"
            prefWidth="220" prefHeight="45"
            onAction="#onGrantPermissions"/>

    <Button fx:id="backButton"
            text="Back"
            styleClass="btn, btn-secondary"
            prefWidth="220" prefHeight="38"
            onAction="#onBack"/>
</VBox>
