<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="16"
      styleClass="permissions-check"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.islemesh.app.components.PermissionsCheck.PermissionsCheckController">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Isle Mesh" styleClass="title"/>

    <Label fx:id="statusLabel"
           text="Checking permissions..."
           styleClass="status-text"
           wrapText="true"
           textAlignment="CENTER"/>

    <Button fx:id="grantButton"
            text="Grant Permissions"
            styleClass="btn, btn-primary"
            prefWidth="220" prefHeight="45"
            visible="false"
            onAction="#onGrantPermissions"/>

    <Button fx:id="retryButton"
            text="Retry"
            styleClass="btn, btn-secondary"
            prefWidth="220" prefHeight="45"
            visible="false"
            onAction="#onRetry"/>
</VBox>
